# === Groq API 키들 ===
# 콤마로 여러 개 등록하면 서버가 자동 라운드로빈
GROQ_KEYS=gsk_xxxxxxxxxxxxxxxxxxxx,gsk_yyyyyyyyyyyyyyyyy

# === Supabase 설정 ===
# Dashboard → Settings → API 에서 확인
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# ⚠️ service_role 키! 절대 클라이언트에 노출 금지
# anon/publishable key가 아니라 service_role key 사용
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiI...

# === 대기열 설정 ===
# 동시 처리 가능한 요청 수. 넘치면 대기열
MAX_CONCURRENT=3

# === CORS ===
# 프론트엔드 도메인 (콤마로 여러 개, * 는 모두 허용)
FRONTEND_ORIGINS=http://localhost:8080,https://mclaw.pages.dev

# === 포트 ===
# Render는 자동으로 PORT 설정
PORT=3000
